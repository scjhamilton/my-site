<style>
.blog-list {
  max-width: 900px;
  margin: 0 auto;
  padding: 2rem 0;
}

.blog-row {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 2.5rem;
  padding: 1.5rem 0;
  align-items: start;
}

.blog-left {
  padding-top: 0.25rem;
}

.blog-title {
  font-size: 0.95rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  line-height: 1.4;
  color: #1C2B4A;
  margin-bottom: 0.5rem;
}

.blog-title a {
  color: inherit;
  text-decoration: none;
}

.blog-title a:hover { color: #8B2500; }

.blog-date {
  font-size: 0.85rem;
  color: #888;
  margin: 0;
}

.blog-image {
  width: 100%;
  border-radius: 4px;
  margin-bottom: 1rem;
  object-fit: cover;
  max-height: 280px;
}

.blog-excerpt {
  font-size: 0.95rem;
  color: #555;
  line-height: 1.7;
  margin-bottom: 0.5rem;
}

.blog-read-more a {
  font-size: 0.9rem;
  color: #8B2500;
  text-decoration: none;
  font-weight: 600;
}

.share-icons {
  display: flex;
  gap: 0.6rem;
  margin-top: 0.75rem;
}

.share-icons a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  background: #1C2B4A;
  color: white;
  border-radius: 50%;
  font-size: 0.9rem;
  text-decoration: none;
}

.share-icons a:hover { background: #8B2500; }

.blog-divider {
  border: none;
  border-top: 1px solid #ddd;
  margin: 0;
}

@media (max-width: 768px) {
  .blog-row {
    grid-template-columns: 1fr;
  }
}
</style>

<div class="blog-list">
<% for (const item of items) { %>
  <hr class="blog-divider" />
  <div class="blog-row">

    <div class="blog-left">
      <h2 class="blog-title">
        <a href="<%= item.path %>"><%= item.title %></a>
      </h2>
      <p class="blog-date">
        <%= new Date(item.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
      </p>
    </div>

    <div class="blog-right">
      <% if (item.image) { %>
        <img src="<%= item.path.replace('index.html', '') + item.image %>"
             alt="<%= item.title %>"
             class="blog-image" />
      <% } %>
      <% if (item.description) { %>
        <p class="blog-excerpt"><%= item.description %></p>
      <% } %>
      <p class="blog-read-more">
        <a href="<%= item.path %>">Read the full post →</a>
      </p>
      <div class="share-icons">
        <a href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(item.title) %>&url=<%= encodeURIComponent(item.path) %>" target="_blank" aria-label="Share on Twitter">
          <i class="fa-brands fa-twitter"></i>
        </a>
        <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent(item.path) %>" target="_blank" aria-label="Share on LinkedIn">
          <i class="fa-brands fa-linkedin"></i>
        </a>
        <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(item.path) %>" target="_blank" aria-label="Share on Facebook">
          <i class="fa-brands fa-facebook"></i>
        </a>
      </div>
    </div>

  </div>
<% } %>
<hr class="blog-divider" />
</div>